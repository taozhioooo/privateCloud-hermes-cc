# ─────────────────────────────────────────────────────────────
# 单员工配置样例 — 复制为 .env.<name> 后填写
#   docker compose --env-file .env.zhangsan -p hermes-zhangsan up -d
# ─────────────────────────────────────────────────────────────

# 员工身份
EMPLOYEE_NAME=zhangsan
EMPLOYEE_SEQ=1
DOMAIN=engineering
ROLE=senior-engineer

# 端口段 (公式: BASE = 10000 + (SEQ-1) * 100, BASE_END = BASE + 99)
# 员工 seq=1  → 10000-10099
# 员工 seq=2  → 10100-10199
# 员工 seq=50 → 14900-14999
BASE=10000
BASE_PLUS_1=10001
BASE_PLUS_2=10002
BASE_PLUS_10=10010
BASE_END=10099

# 访问约定:
#   BASE        -> SSH        -> 容器 8700
#   BASE_PLUS_1 -> Web UI     -> 容器 8701
#   BASE_PLUS_2 -> Gateway    -> 容器 8642 (hermes-agent 官方默认 API server 端口,容器内监听 0.0.0.0)
#   BASE_PLUS_10..BASE_END -> 临时服务 -> 容器 8710..8799

# SSH 公钥 (必填,否则无法登录)
# 多把 key 用 \n 分隔写在一行,或用 Compose 的 | 多行字符串
SSH_PUBLIC_KEY=ssh-ed25519 AAAAC3NzaC1lZDI1NTE5... admin@company

# 模型渠道默认值。留空则按 /opt/hermes/company-providers.yaml 的优先级自动选择。
HERMES_DEFAULT_PROVIDER=
HERMES_DEFAULT_MODEL=
COMPANY_PROVIDERS_FILE=

# API keys — 首次启动写入 /opt/data/.env, 写入后用户接管
DEEPSEEK_API_KEY=sk-xxx
DASHSCOPE_API_KEY=
MINIMAX_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
CUSTOM_API_KEY=

# 可选: 钉钉 gateway
DINGTALK_CLIENT_ID=
DINGTALK_CLIENT_SECRET=
DINGTALK_ALLOWED_USERS=

# 镜像名(构建后打的 tag)
HERMES_IMAGE=registry.cn-chengdu.aliyuncs.com/gmsoft_hub/hermes-agent:2025051201
