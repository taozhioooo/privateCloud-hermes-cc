# =============================================================================
# Auto-generated by scripts/lib/render.py - DO NOT EDIT MANUALLY
# User: {{ name }} (seq={{ seq }})
# Hermes: {{ h_ssh_port }}=SSH, {{ h_web_start }}-{{ h_web_end }}=Web
# Claude: {{ c_ssh_port }}=SSH, {{ c_web_start }}-{{ c_web_end }}=Web
# =============================================================================

services:
  hermes-{{ name }}:
    image: {{ image_hermes }}
    container_name: hermes-{{ name }}
    restart: unless-stopped
    hostname: hermes-{{ name }}
    environment:
      # LLM Provider API Keys
      - DEEPSEEK_API_KEY=${DEEPSEEK_API_KEY:-}
      - MINIMAX_API_KEY=${MINIMAX_API_KEY:-}
      - DASHSCOPE_API_KEY=${DASHSCOPE_API_KEY:-}
      - ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY:-}
      - OPENROUTER_API_KEY=${OPENROUTER_API_KEY:-}
      - CUSTOM_API_KEY=${CUSTOM_API_KEY:-}
      # 网络搜索
      - BRAVE_API_KEY=${BRAVE_API_KEY:-}
      - GOOGLE_API_KEY=${GOOGLE_API_KEY:-}
      - GITHUB_TOKEN=${GITHUB_TOKEN:-}
      # 钉钉（与 images/hermes-agent/config/company-providers.yaml 保持一致）
      - DINGTALK_CLIENT_ID=${DINGTALK_CLIENT_ID:-}
      - DINGTALK_CLIENT_SECRET=${DINGTALK_CLIENT_SECRET:-}
      - DINGTALK_ALLOWED_USERS=${DINGTALK_ALLOWED_USERS:-}
      # 员工身份
      - EMPLOYEE_NAME={{ name }}
      - EMPLOYEE_SEQ={{ '%02d' | format(seq) }}
      - DOMAIN={{ domain }}
      - ROLE={{ role }}
      # Team Skills 自动同步：入口只远程执行脚本；频率/仓库地址等由远程 scripts/config.env 控制
      - EMPLOYEE_ID={{ employee_id }}
      - GITLAB_PRIVATE_TOKEN=${GITLAB_PRIVATE_TOKEN:-}
      - SKILLS_RAW_BASE=${SKILLS_RAW_BASE:-}
      - SKILLS_REF=${SKILLS_REF:-master}
      - SKILLS_SYNC_INTERVAL=${SKILLS_SYNC_INTERVAL:-300}
      # 端口信息
      - SSH_PORT={{ h_ssh_port }}
      - WEB_PORT_START={{ h_web_start }}
      - WEB_PORT_END={{ h_web_end }}
      - CLAUDE_HOST=claude-{{ name }}
      - CLAUDE_SSH_PORT=22
      # SSH
      - HERMES_SSH_PASS=hermes
      - HERMES_MODE={{ hermes_mode }}
{%- if ssh_public_keys %}
      - SSH_PUBLIC_KEY={{ ssh_public_keys | join('\n') }}
{%- endif %}
    ports:
      # 当前 hermes-agent all-in-one 镜像内部固定端口：8700 SSH, 8701 WebUI,
      # 8642 Gateway/API, 8710-8799 临时服务。宿主机按员工 seq 映射。
      - "{{ h_ssh_port }}:8700"
      - "{{ h_web_start }}:8701"
      - "{{ h_web_start + 1 }}:8642"
      - "{{ h_web_start + 9 }}-{{ h_web_end }}:8710-{{ 8710 + (h_web_end - (h_web_start + 9)) }}"
    volumes:
      # 每个员工的全部运行时文件集中放在 data/<姓名>-<工号>/，便于作为 Windows 网络磁盘挂载。
      - ./data/{{ user_data_dir }}/hermes:/opt/data
      - ./data/{{ user_data_dir }}/workspace:/workspace
      - ./data/{{ user_data_dir }}/ssh-pub:/home/hermes/.ssh-pub
    networks:
      - hermes-net
    deploy:
      resources:
        limits:
          cpus: "{{ resources.hermes.cpus }}"
          memory: {{ resources.hermes.memory }}
    security_opt:
      - no-new-privileges:true

  claude-{{ name }}:
    image: {{ image_claude }}
    container_name: claude-{{ name }}
    restart: unless-stopped
    hostname: claude-{{ name }}
    environment:
      - ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY:-}
      - CLAUDE_SSH_PASS=claude
      - EMPLOYEE_NAME={{ name }}
      - EMPLOYEE_SEQ={{ '%02d' | format(seq) }}
      - SSH_PORT={{ c_ssh_port }}
      - SSHD_LISTEN_PORT=22
      - WEB_PORT_START={{ c_web_start }}
      - WEB_PORT_END={{ c_web_end }}
      - HERMES_HOST=hermes-{{ name }}
{%- if ssh_public_keys %}
      - SSH_PUBLIC_KEY={{ ssh_public_keys | join('\n') }}
{%- endif %}
    ports:
      - "{{ c_ssh_port }}:22"
      - "{{ c_web_start }}-{{ c_web_end }}:{{ c_web_start }}-{{ c_web_end }}"
    volumes:
      - ./data/{{ user_data_dir }}/workspace:/home/claude/workspace
      - ./data/{{ user_data_dir }}/ssh-pub:/hermes-ssh-pub:ro
      # Claude Code 官方默认读取 ~/.claude/settings.json；该目录持久化后用户可自行修改。
      - ./data/{{ user_data_dir }}/claude-home:/home/claude/.claude
      # 公司默认模板：entrypoint 仅在 ~/.claude/settings.json 不存在时复制一次，后续不覆盖用户配置。
      - ./config/claude-settings.json:/etc/claude/settings.json:ro
    networks:
      - hermes-net
    deploy:
      resources:
        limits:
          cpus: "{{ resources.claude.cpus }}"
          memory: {{ resources.claude.memory }}
    security_opt:
      - no-new-privileges:true

networks:
  hermes-net:
    external: true
    name: hermes-net
