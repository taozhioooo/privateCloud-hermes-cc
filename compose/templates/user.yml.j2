# =============================================================================
# Auto-generated by scripts/lib/render.py - DO NOT EDIT MANUALLY
# User: {{ name }} (seq={{ seq }})
# Hermes: {{ h_ssh_port }}=SSH, {{ h_web_start }}-{{ h_web_end }}=Web
# Claude: {{ c_ssh_port }}=SSH, {{ c_web_start }}-{{ c_web_end }}=Web
# =============================================================================

services:
  hermes-{{ name }}:
    image: {{ image_hermes }}
    container_name: hermes-{{ name }}
    restart: unless-stopped
    hostname: hermes-{{ name }}
    environment:
      # LLM Provider API Keys
      - DEEPSEEK_API_KEY=${DEEPSEEK_API_KEY:-}
      - MINIMAX_API_KEY=${MINIMAX_API_KEY:-}
      - DASHSCOPE_API_KEY=${DASHSCOPE_API_KEY:-}
      - ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY:-}
      - OPENROUTER_API_KEY=${OPENROUTER_API_KEY:-}
      - CUSTOM_API_KEY=${CUSTOM_API_KEY:-}
      # 网络搜索
      - BRAVE_API_KEY=${BRAVE_API_KEY:-}
      - GOOGLE_API_KEY=${GOOGLE_API_KEY:-}
      - GITHUB_TOKEN=${GITHUB_TOKEN:-}
      # 钉钉
      - DINGTALK_APP_KEY=${DINGTALK_APP_KEY:-}
      - DINGTALK_APP_SECRET=${DINGTALK_APP_SECRET:-}
      # 员工身份
      - EMPLOYEE_NAME={{ name }}
      - EMPLOYEE_SEQ={{ '%02d' | format(seq) }}
      - DOMAIN={{ domain }}
      - ROLE={{ role }}
      # 端口信息
      - SSH_PORT={{ h_ssh_port }}
      - WEB_PORT_START={{ h_web_start }}
      - WEB_PORT_END={{ h_web_end }}
      - CLAUDE_HOST=claude-{{ name }}
      - CLAUDE_SSH_PORT={{ c_ssh_port }}
      # SSH
      - HERMES_SSH_PASS=hermes
      - HERMES_MODE={{ hermes_mode }}
{%- if ssh_public_keys %}
      - SSH_PUBLIC_KEY={{ ssh_public_keys | join('\n') }}
{%- endif %}
    ports:
      - "{{ h_ssh_port }}:22"
      - "{{ h_web_start }}-{{ h_web_end }}:{{ h_web_start }}-{{ h_web_end }}"
    volumes:
      - {{ name }}_hermes:/home/hermes/.hermes
      - {{ name }}_workspace:/home/hermes/workspace
      - {{ name }}_ssh_pub:/home/hermes/.ssh-pub
      - ../../skills/L1:/opt/skills/L1:ro
      - ../../skills/L2:/opt/skills/L2:ro
      - ../../skills/L3:/opt/skills/L3:ro
    networks:
      - hermes-net
    depends_on:
      redis:
        condition: service_healthy
    deploy:
      resources:
        limits:
          cpus: "{{ resources.hermes.cpus }}"
          memory: {{ resources.hermes.memory }}
    security_opt:
      - no-new-privileges:true

  claude-{{ name }}:
    image: {{ image_claude }}
    container_name: claude-{{ name }}
    restart: unless-stopped
    hostname: claude-{{ name }}
    environment:
      - ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY:-}
      - CLAUDE_SSH_PASS=claude
      - EMPLOYEE_NAME={{ name }}
      - EMPLOYEE_SEQ={{ '%02d' | format(seq) }}
      - SSH_PORT={{ c_ssh_port }}
      - WEB_PORT_START={{ c_web_start }}
      - WEB_PORT_END={{ c_web_end }}
      - HERMES_HOST=hermes-{{ name }}
{%- if ssh_public_keys %}
      - SSH_PUBLIC_KEY={{ ssh_public_keys | join('\n') }}
{%- endif %}
    ports:
      - "{{ c_ssh_port }}:22"
      - "{{ c_web_start }}-{{ c_web_end }}:{{ c_web_start }}-{{ c_web_end }}"
    volumes:
      - {{ name }}_workspace:/home/claude/workspace
      - {{ name }}_ssh_pub:/hermes-ssh-pub:ro
    networks:
      - hermes-net
    deploy:
      resources:
        limits:
          cpus: "{{ resources.claude.cpus }}"
          memory: {{ resources.claude.memory }}
    security_opt:
      - no-new-privileges:true

networks:
  hermes-net:
    external: true
    name: hermes-net

volumes:
  {{ name }}_hermes:
  {{ name }}_workspace:
  {{ name }}_ssh_pub:
