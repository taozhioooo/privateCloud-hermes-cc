# =============================================================================
# Hermes Enterprise Platform — 环境变量
# 复制此文件为 .env: cp .env.example .env
#
# 容器启动时自动检测哪些 Key 存在，选择第一个可用的 Provider
# 用户可通过 hermes model 自主切换
# =============================================================================

# ── LLM Provider API Key（填入公司提供的任意一个即可）──
# 容器会按以下优先级自动选择: deepseek → dashscope → minimax → openrouter → anthropic → openai → gemini → custom

# DeepSeek（推荐，性价比高）
DEEPSEEK_API_KEY=

# MiniMax（长上下文）
MINIMAX_API_KEY=

# 阿里百炼 Qwen（国内稳定）
DASHSCOPE_API_KEY=

# Anthropic Claude（海外最强）
ANTHROPIC_API_KEY=

# OpenRouter（多模型路由）
OPENROUTER_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Gemini
GEMINI_API_KEY=

# 公司自建模型
CUSTOM_API_KEY=

# ── 网络搜索 API（推荐配置）──
BRAVE_API_KEY=
GOOGLE_API_KEY=
GITHUB_TOKEN=

# ── Team Skills 远程脚本入口（可选）──
# 每个员工的工号由 users/users.yaml 的 employee_id 渲染到容器。
# 远程仓库访问 token 运行时注入；不要提交真实值，也不会写入镜像。
GITLAB_PRIVATE_TOKEN=
# 远程脚本 bootstrap 入口；GitLab project path 中的 / 需编码为 %2F。
SKILLS_RAW_BASE=https://gitlab.gm/api/v4/projects/devops%2Fgmsoft-hermes-skills/repository/files
SKILLS_REF=master
SKILLS_SYNC_INTERVAL=300

# ── 钉钉集成（可选）──
# 当前 Hermes entrypoint/provider 配置读取 DINGTALK_CLIENT_ID / DINGTALK_CLIENT_SECRET。
# 不再使用旧变量名 DINGTALK_APP_KEY / DINGTALK_APP_SECRET。
DINGTALK_CLIENT_ID=
DINGTALK_CLIENT_SECRET=
DINGTALK_ALLOWED_USERS=

# ── SSH 配置（可选）──
# HERMES_SSH_PASS=hermes
# CLAUDE_SSH_PASS=claude
# SSH_PUBLIC_KEY=ssh-ed25519 AAAA... user@host
